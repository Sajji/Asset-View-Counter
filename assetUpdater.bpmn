<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:flowable="http://flowable.org/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:design="http://flowable.org/design" typeLanguage="http://www.w3.org/2001/XMLSchema" expressionLanguage="http://www.w3.org/1999/XPath" targetNamespace="http://www.collibra.com/apiv2" exporter="Flowable Design" exporterVersion="2025.1.08" design:palette="flowable-core-process-palette">
  <process id="pageViewUpdate" name="Page View Update" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-03-19T18:15:01.856Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-03-19T19:53:57.772Z]]></design:modificationdate>
    </extensionElements>
    <scriptTask id="ScriptTask_1" name="Increment Page View Count on Current Asset" scriptFormat="groovy" flowable:autoStoreVariables="false">
      <extensionElements>
        <design:stencilid><![CDATA[ScriptTask]]></design:stencilid>
      </extensionElements>
      <script><![CDATA[import com.collibra.dgc.core.api.dto.instance.attribute.AddAttributeRequest
import com.collibra.dgc.core.api.dto.instance.attribute.FindAttributesRequest;
import com.collibra.dgc.core.api.dto.instance.asset.SetAssetAttributesRequest
import com.collibra.dgc.core.api.dto.instance.asset.ChangeAssetRequest


def curPageViewCountUuid = attributeTypeApi.getAttributeTypeByName("Page Views").getId()

if (execution.getVariable('newPageViewCount')) {
    assetApi.setAssetAttributes(SetAssetAttributesRequest.builder()
        .assetId(item.getId())
        .typeId(curPageViewCountUuid)
        .values([newPageViewCount])
        .build())
}


def curPageViewCountFound = attributeApi.findAttributes(
    FindAttributesRequest.builder()
        .typeIds([curPageViewCountUuid])
        .assetId(item.getId())
        .build()
).getResults()

def newPageViewCount
if (curPageViewCountFound.isEmpty()) {
    // First time — no attribute exists yet
    newPageViewCount = 1
} else {
    // Attribute exists — read current value and increment
    def currentValue = curPageViewCountFound[0].getValue()
    newPageViewCount = currentValue.toInteger() + 1
}

execution.setVariable('newPageViewCount', newPageViewCount)

assetApi.setAssetAttributes(SetAssetAttributesRequest.builder()
    .assetId(item.getId())
    .typeId(curPageViewCountUuid)
    .values([newPageViewCount])
    .build())]]></script>
    </scriptTask>
    <startEvent id="startnoneevent1" name="Start" flowable:initiator="initiator">
      <extensionElements>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </startEvent>
    <endEvent id="EndNoneEvent_3" name="End">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </endEvent>
    <sequenceFlow id="SequenceFlow_4" sourceRef="ScriptTask_1" targetRef="EndNoneEvent_3">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_2" sourceRef="startnoneevent1" targetRef="ScriptTask_1">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
  </process>
